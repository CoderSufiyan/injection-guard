{
  "name": "injection-guard",
  "version": "0.1.1",
  "description": "Detect and sanitize prompt injection attacks in LLM applications. Zero dependencies. TypeScript-first.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "llm",
    "prompt-injection",
    "ai-security",
    "openai",
    "anthropic",
    "prompt",
    "security",
    "middleware",
    "typescript"
  ],
  "author": "Sufiyan Khan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CoderSufiyan/injection-guard"
  },
  "homepage": "https://github.com/CoderSufiyan/injection-guard",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
